diff --git a/styles.css b/styles.css
--- a/styles.css
+++ b/styles.css
@@
+/* Remove stale status detail overrides:
+   - .status-page .status-item-meta blocks
+   - repeated .status-page .status-badge width-only blocks
+   - older appended "Status detail page grid alignment" blocks
+*/
+
+/* Status page final layout */
+.status-page .status-list {
+  display: grid !important;
+  gap: 10px !important;
+}
+
+.status-page .status-item {
+  display: grid !important;
+  grid-template-columns: 140px minmax(0, 1fr) 160px 100px !important;
+  align-items: center !important;
+  gap: 16px !important;
+  padding: 14px 18px !important;
+}
+
+.status-page .status-time {
+  grid-column: 1 !important;
+  min-width: 0 !important;
+  white-space: nowrap !important;
+}
+
+.status-page .status-product {
+  grid-column: 2 !important;
+  display: flex !important;
+  align-items: center !important;
+  gap: 10px !important;
+  min-width: 0 !important;
+  overflow: hidden !important;
+}
+
+.status-page .status-product-icon {
+  width: 30px !important;
+  height: 30px !important;
+  min-width: 30px !important;
+  border-radius: 10px !important;
+  overflow: hidden !important;
+  display: inline-flex !important;
+  align-items: center !important;
+  justify-content: center !important;
+  background: #fff !important;
+  border: 1px solid #e6edf7 !important;
+}
+
+.status-page .status-product-logo {
+  width: 100% !important;
+  height: 100% !important;
+  object-fit: contain !important;
+  display: block !important;
+}
+
+.status-page .status-product-name {
+  min-width: 0 !important;
+  overflow: hidden !important;
+  text-overflow: ellipsis !important;
+  white-space: nowrap !important;
+}
+
+.status-page .status-amount {
+  grid-column: 3 !important;
+  width: 160px !important;
+  justify-self: end !important;
+  text-align: right !important;
+  white-space: nowrap !important;
+}
+
+.status-page .status-badge {
+  grid-column: 4 !important;
+  width: 100px !important;
+  min-width: 100px !important;
+  justify-self: end !important;
+  box-sizing: border-box !important;
+  text-align: center !important;
+  white-space: nowrap !important;
+}
+
+@media (max-width: 640px) {
+  .status-page .status-item {
+    grid-template-columns: minmax(0, 1fr) auto !important;
+    grid-template-areas:
+      "time badge"
+      "product amount" !important;
+    gap: 8px 12px !important;
+    padding: 12px 14px !important;
+  }
+
+  .status-page .status-time {
+    grid-area: time !important;
+  }
+
+  .status-page .status-product {
+    grid-area: product !important;
+  }
+
+  .status-page .status-amount {
+    grid-area: amount !important;
+    width: auto !important;
+    justify-self: end !important;
+  }
+
+  .status-page .status-badge {
+    grid-area: badge !important;
+    width: auto !important;
+    min-width: 72px !important;
+  }
+}
